      <aliases enabled='yes' />
      <column caption='Asin' datatype='string' name='[ASIN]' role='dimension' type='nominal' />
      <column caption='revenue share %' datatype='real' default-format='p0.0%' name='[Calculation_2572009422524416]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Amount]) / TOTAL(SUM([Amount]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Shipped Flag' datatype='integer' name='[Calculation_2572010048036865]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Status] = &quot;Shipped&quot; OR [Status] = &quot;Shipped - Delivered to Buyer&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Fulfillment Rate' datatype='real' name='[Calculation_2572010049998854]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_2572010048036865]) / COUNT([Order ID])' />
      </column>
